<?xml version="1.0" encoding="UTF-8"?>
	<project name="starparse-client" default="do-deploy" basedir="."  xmlns:fx="javafx:com.sun.javafx.tools.ant">
	<property environment="env"/>
	<!-- no longer needed with standard ant tasks and jpackage -->
	<target name="setup-staging-area">
		<delete dir="externalLibs" />
		<delete dir="project" />
		<delete dir="projectRefs" />

		<mkdir dir="externalLibs" />

		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\com\thoughtworks\xstream\xstream\1.4.21">
				<filename name="xstream-1.4.21.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\javax\websocket\javax.websocket-api\1.1">
				<filename name="javax.websocket-api-1.1.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\com\h2database\h2\2.4.240">
				<filename name="h2-2.4.240.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\log4j\log4j\1.2.17">
				<filename name="log4j-1.2.17.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\springframework\spring-context\7.0.6">
				<filename name="spring-context-7.0.6.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\springframework\spring-jdbc\7.0.6">
				<filename name="spring-jdbc-7.0.6.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\springframework\spring-beans\7.0.6">
				<filename name="spring-beans-7.0.6.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\springframework\spring-core\7.0.6">
				<filename name="spring-core-7.0.6.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\springframework\spring-tx\7.0.6">
				<filename name="spring-tx-7.0.6.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\springframework\spring-aop\7.0.6">
				<filename name="spring-aop-7.0.6.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\springframework\spring-expression\7.0.6">
				<filename name="spring-expression-7.0.6.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\slf4j\slf4j-api\2.0.16">
				<filename name="slf4j-api-2.0.16.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\slf4j\jcl-over-slf4j\2.0.16">
				<filename name="jcl-over-slf4j-2.0.16.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\slf4j\slf4j-reload4j\2.0.16">
				<filename name="slf4j-reload4j-2.0.16.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\cglib\cglib-nodep\3.3.0">
				<filename name="cglib-nodep-3.3.0.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\glassfish\tyrus\bundles\tyrus-standalone-client-jdk\2.2.2">
				<filename name="tyrus-standalone-client-jdk-2.2.2.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\com\esotericsoftware\kryo\kryo\2.24.0">
				<filename name="kryo-2.24.0.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\javax\inject\javax.inject\1">
				<filename name="javax.inject-1.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\net\java\dev\jna\jna-platform\5.18.1">
				<filename name="jna-platform-5.18.1.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\net\java\dev\jna\jna\5.18.1">
				<filename name="jna-5.18.1.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\openjfx\javafx-controls\26">
				<include name="javafx-controls-26.jar"/>
				<include name="javafx-controls-26-win.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\openjfx\javafx-fxml\26">
				<include name="javafx-fxml-26.jar"/>
				<include name="javafx-fxml-26-win.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\openjfx\javafx-media\26">
				<include name="javafx-media-26.jar"/>
				<include name="javafx-media-26-win.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\openjfx\javafx-swing\26">
				<include name="javafx-swing-26.jar"/>
				<include name="javafx-swing-26-win.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\openjfx\javafx-base\26">
				<include name="javafx-base-26.jar"/>
				<include name="javafx-base-26-win.jar"/>
			</fileset>
		</copy>
		<copy todir="externalLibs">
			<fileset dir="${user.home}\.m2\repository\org\openjfx\javafx-graphics\26">
				<include name="javafx-graphics-26.jar"/>
				<include name="javafx-graphics-26-win.jar"/>
			</fileset>
		</copy>

		<mkdir dir="project" />
		<copy todir="project">
			<fileset dir="..">
				<include name="src\main\resources/**" />
			</fileset>
		</copy>
		<copy todir="project">
			<fileset dir="..">
				<include name="src\main\java/**" />
			</fileset>
		</copy>

		<mkdir dir="projectRefs" />
	</target>
	<target name='do-compile'>
		<delete dir="build" />
		<mkdir dir="build/src" />
		<mkdir dir="build/libs" />
		<mkdir dir="build/classes" />

		<!-- Copy project-libs references -->
		<copy todir="build/libs">
			<fileset dir="externalLibs">
				<include name="xstream-1.4.21.jar"/>
				<include name="javax.websocket-api-1.1.jar"/>
				<include name="h2-2.4.240.jar"/>
				<include name="log4j-1.2.17.jar"/>
				<include name="spring-context-7.0.6.jar"/>
				<include name="spring-jdbc-7.0.6.jar"/>
				<include name="spring-beans-7.0.6.jar"/>
				<include name="spring-core-7.0.6.jar"/>
				<include name="spring-tx-7.0.6.jar"/>
				<include name="spring-aop-7.0.6.jar"/>
				<include name="spring-expression-7.0.6.jar"/>
				<include name="slf4j-api-2.0.16.jar"/>
				<include name="jcl-over-slf4j-2.0.16.jar"/>
				<include name="slf4j-reload4j-2.0.16.jar"/>
				<include name="cglib-nodep-3.3.0.jar"/>
				<include name="tyrus-standalone-client-jdk-2.2.2.jar"/>
				<include name="kryo-2.24.0.jar"/>
				<include name="javax.inject-1.jar"/>
				<include name="jna-platform-5.18.1.jar"/>
				<include name="jna-5.18.1.jar"/>
				<include name="javafx-controls-26-win.jar"/>
				<include name="javafx-fxml-26-win.jar"/>
				<include name="javafx-media-26-win.jar"/>
				<include name="javafx-swing-26-win.jar"/>
				<include name="javafx-base-26-win.jar"/>
				<include name="javafx-graphics-26-win.jar"/>
			</fileset>
		</copy>

		<!-- Copy project references -->

		<!-- Copy project sources itself -->
		<copy todir="build/src">
			<fileset dir="project/src/main/resources">
				<include name="**/*"/>
			</fileset>
		</copy>
		<copy todir="build/src">
			<fileset dir="project/src/main/java">
				<include name="**/*"/>
			</fileset>
		</copy>
		<copy todir="build/src">
			<fileset dir="../../starparse-shared/src/main/resources">
				<include name="**/*"/>
			</fileset>
		</copy>
		<copy todir="build/src">
			<fileset dir="../../starparse-shared/src/main/java">
				<include name="**/*"/>
			</fileset>
		</copy>

		<javac includeantruntime="false" release="26" srcdir="build/src" destdir="build/classes" encoding="windows-1252">
			<classpath>
				<fileset dir="build/libs">
					<include name="*"/>
				</fileset>
			</classpath>
		</javac>

		<!-- Copy over none Java-Files -->
		<copy todir="build/classes">
		<fileset dir="project/src/main/resources">
			<exclude name="**/*.java"/>
			<exclude name="**/log4j.debug.xml"/>
		</fileset>
		<fileset dir="project/src/main/java">
			<exclude name="**/*.java"/>
		</fileset>
		</copy>


	</target>
	<target name="do-deploy" depends="setup-staging-area, do-compile">
		<delete file="dist"/>
		<delete file="deploy" />

		<mkdir dir="dist" />
		<mkdir dir="dist/libs" />

		<copy todir="dist/libs">
			<fileset dir="externalLibs">
				<include name="*" />
			</fileset>
		</copy>

		<mkdir dir="build/classes/META-INF" />

		<manifestclasspath property="lib.list" jarfile="dist/starparse-client.jar">
			<classpath>
				<fileset dir="dist/libs">
					<include name="*.jar"/>
				</fileset>
			</classpath>
		</manifestclasspath>

		<jar destfile="dist/starparse-client.jar">
			<fileset dir="build/classes" />
			<manifest>
				<attribute name="Implementation-Vendor" value="Ixale"/>
				<attribute name="Implementation-Title" value="StarParse"/>
				<attribute name="Implementation-Version" value="1.0"/>
				<attribute name="Main-Class" value="com.ixale.starparse.gui.Launcher"/>
				<attribute name="Class-Path" value="${lib.list}"/>
			</manifest>
		</jar>

		<mkdir dir="deploy" />
		<exec executable="${env.JAVA_HOME}\bin\jpackage.exe">
			<arg value="--type"/><arg value="app-image"/>
			<arg value="--name"/><arg value="StarParse"/>
			<arg value="--input"/><arg value="dist"/>
			<arg value="--main-jar"/><arg value="starparse-client.jar"/>
			<arg value="--main-class"/><arg value="com.ixale.starparse.gui.Launcher"/>
			<arg value="--dest"/><arg value="deploy/bundles"/>
			<arg value="--icon"/><arg value="package/windows/StarParse.ico"/>
			<arg value="--java-options"/><arg value="-Dfile.encoding=COMPAT -Xmx400m -XX:+UseG1GC --enable-native-access=ALL-UNNAMED --add-opens=javafx.graphics/javafx.stage=ALL-UNNAMED --add-opens=javafx.graphics/com.sun.javafx.tk=ALL-UNNAMED --add-opens=javafx.graphics/com.sun.javafx.tk.quantum=ALL-UNNAMED --add-opens=javafx.graphics/com.sun.glass.ui=ALL-UNNAMED --add-opens=javafx.graphics/com.sun.glass.ui.win=ALL-UNNAMED"/>
		</exec>

		<copy todir="StarParse">
			<fileset dir="deploy/bundles/StarParse">
				<include name="*" />
			</fileset>
		</copy>

		<copy todir="StarParse">
			<fileset dir="deploy/bundles/StarParse" includes="**/*" />
		</copy>

		<copy todir="StarParse/app/icons">
			<fileset dir="../icons" includes="**/*" />
		</copy>

		<copy todir="StarParse/app/sounds">
			<fileset dir="../sounds" includes="**/*" />
		</copy>

		<delete dir="build"/>
		<delete dir="deploy"/>
		<delete dir="dist"/>
		<delete dir="externalLibs"/>
		<delete dir="project"/>
		<delete dir="projectRefs"/>

	</target>
</project>
